# Copy to .env and fill in. Never commit the real .env.

# ---- Sudco Solutions API (where prospects + demos are stored) ----
SUDCO_API_BASE=
# OR for local dev against the dev backend:
# SUDCO_API_BASE=http://localhost:3001/api
SUDCO_ADMIN_API_KEY=

# ---- Local LLM (llama.cpp / Qwen on this box) ----
LLM_BASE_URL=http://127.0.0.1:8011/v1
LLM_API_KEY=not-needed
LLM_TEXT_MODEL=qwen3.6-35b-a3b
LLM_VISION_MODEL=qwen3-vl-30b-a3b-instruct

# ---- Discovery ----
# Free tier: 1000 calls/day. Sign up at https://foursquare.com/developers/
FOURSQUARE_API_KEY=

# ---- Image sourcing ----
# Free, generous limits. https://www.pexels.com/api/
PEXELS_API_KEY=

# ---- Outbound email (uses the same docker-mailserver as sudcosolutions.com) ----
# Use mail.sudcosolutions.com (not 'localhost') so the TLS cert verifies cleanly.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# IMAP — used to save a copy of every outbound to the Sent folder so it shows
# up in webmail / Apple Mail / Outlook. Defaults to SMTP_HOST + port 993 (IMAPS).
# Leave IMAP_HOST empty to disable Sent-folder saving entirely.
IMAP_HOST=
IMAP_PORT=993
IMAP_SENT_FOLDER=Sent

# ---- Outreach (cold-blast: shared sample sites by industry) ----
# `agent send-cold --industry bakery` links to {COLD_DEMO_BASE_URL}/bakery?from=<prospect_id>
COLD_DEMO_BASE_URL=

# ---- Behavior ----
DEMO_EXPIRES_DAYS=30
FOLLOWUP_AFTER_DAYS=7
DRY_RUN=false
